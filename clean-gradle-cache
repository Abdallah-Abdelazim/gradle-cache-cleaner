#!/usr/bin/env bash
# clean-gradle-cache
#
# Scans Maven and Gradle dependency caches and deletes all but the latest
# version of each artifact.
#
# Usage:
#   ./clean-gradle-cache            # delete old versions, keep latest
#   ./clean-gradle-cache --all      # delete all versions including latest and SNAPSHOTs
#   ./clean-gradle-cache --dry-run  # preview without deleting (combine with --all)

set -euo pipefail

DRY_RUN=false
ALL=false
for arg in "$@"; do
  case "$arg" in
    --dry-run) DRY_RUN=true ;;
    --all)     ALL=true ;;
    *) echo "Unknown option: $arg"; echo "Usage: $0 [--all] [--dry-run]"; exit 1 ;;
  esac
done

$DRY_RUN && echo "[DRY RUN — nothing will be deleted]" && echo ""

# Sort version strings lowest-first using version-aware sort (-V flag).
sort_versions() {
  sort -V
}

human_size() {
  awk -v kb="$1" 'BEGIN {
    if      (kb >= 1048576) printf "%.1fG", kb / 1048576
    else if (kb >= 1024)    printf "%.1fM", kb / 1024
    else                    printf "%dK",   kb
  }'
}

deleted=0
total_kb=0

# Prune an artifact directory: delete every versioned subdirectory except the latest.
# With --all: delete every versioned subdirectory including SNAPSHOTs and the latest.
# Argument: path like ~/.m2/repository/com/example/foo
#            or ~/.gradle/caches/.../files-2.1/com.example/foo
prune_artifact() {
  local dir="$1"

  # Collect subdirs that start with a digit (version-like).
  # Skip SNAPSHOT builds unless --all is set.
  local ver_dirs=()
  while IFS= read -r -d '' d; do
    local name; name="$(basename "$d")"
    [[ "$name" =~ ^[0-9] ]] || continue
    $ALL || [[ "$name" != *-SNAPSHOT ]] || continue
    ver_dirs+=("$name")
  done < <(find "$dir" -mindepth 1 -maxdepth 1 -type d -print0 2>/dev/null)

  (( ${#ver_dirs[@]} == 0 )) && return
  ! $ALL && (( ${#ver_dirs[@]} <= 1 )) && return

  # Sort; the last element after sorting is the latest version.
  local sorted=()
  while IFS= read -r line; do
    sorted+=("$line")
  done < <(printf '%s\n' "${ver_dirs[@]}" | sort_versions)

  local latest="${sorted[$(( ${#sorted[@]} - 1 ))]}"
  local limit
  $ALL && limit=${#sorted[@]} || limit=$(( ${#sorted[@]} - 1 ))

  local i
  for (( i = 0; i < limit; i++ )); do
    local target="$dir/${sorted[$i]}"
    local kb; kb=$(du -sk "$target" 2>/dev/null | awk '{print $1}') || kb=0
    local size; size=$(human_size "$kb")
    total_kb=$(( total_kb + kb ))
    if $DRY_RUN; then
      $ALL \
        && echo "  [would delete] $target  ($size)" \
        || echo "  [would delete] $target  ($size)  → keep $latest"
    else
      echo "  deleting  $target  ($size)"
      rm -rf "$target"
    fi
    (( deleted++ , 1 ))
  done
}

# ── Maven local repo (~/.m2/repository) ──────────────────────────────────────
# Layout: REPO/group/path/artifact/VERSION/artifact-VERSION.pom
# Strip the last two path components of every .pom to get the artifact dir.
M2="$HOME/.m2/repository"
if [[ -d "$M2" ]]; then
  echo "Scanning $M2 ..."
  declare -A _seen_m2=()
  while IFS= read -r -d '' pom; do
    artifact_dir="$(dirname "$(dirname "$pom")")"
    [[ -v _seen_m2["$artifact_dir"] ]] && continue
    _seen_m2["$artifact_dir"]=1
    prune_artifact "$artifact_dir"
  done < <(find "$M2" -name "*.pom" -not -path "*/\.*" -print0 2>/dev/null)
fi

# ── Gradle files cache (~/.gradle/caches/modules-2/files-2.1) ────────────────
# Layout: files-2.1/GROUP/ARTIFACT/VERSION/HASH/file
# Artifact dirs are always exactly 2 levels deep.
GRADLE="$HOME/.gradle/caches/modules-2/files-2.1"
if [[ -d "$GRADLE" ]]; then
  echo ""
  echo "Scanning $GRADLE ..."
  while IFS= read -r -d '' artifact_dir; do
    prune_artifact "$artifact_dir"
  done < <(find "$GRADLE" -mindepth 2 -maxdepth 2 -type d -print0 2>/dev/null)
fi

echo ""
plural() { (( $1 == 1 )) && echo "directory" || echo "directories"; }
total=$(human_size "$total_kb")
if $DRY_RUN; then
  if (( deleted == 0 )); then
    echo "Dry run — nothing to remove."
  else
    echo "Dry run — $deleted version $(plural $deleted) would be removed ($total)."
    echo "Run without --dry-run to delete."
  fi
else
  if (( deleted == 0 )); then
    echo "Nothing to remove — cache is already clean."
  else
    echo "Done — removed $deleted old version $(plural $deleted) ($total freed)."
  fi
fi
